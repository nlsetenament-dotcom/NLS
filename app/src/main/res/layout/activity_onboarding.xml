<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header negro fijo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#000000"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NLS"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvStepIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Paso 1 de 5"
            android:textColor="#9E9E9E"
            android:textSize="12sp"
            android:layout_marginBottom="10dp"/>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:progress="20"
            android:progressTint="#FFFFFF"
            android:progressBackgroundTint="#333333"/>
    </LinearLayout>

    <!-- Contenido con scroll -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- PASO 0: Nombre y Genero -->
            <LinearLayout android:id="@+id/step0Layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Como se llamara?"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginBottom="6dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Elige el nombre y genero de tu companero/a."
                    android:textSize="13sp"
                    android:textColor="#9E9E9E"
                    android:layout_marginBottom="24dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nombre"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="24dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCompanionName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName|textCapWords"
                        android:maxLength="20"/>
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Genero"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginBottom="12dp"/>

                <RadioGroup android:id="@+id/rgGender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbFemale"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Femenino"
                        android:checked="true"
                        android:layout_marginBottom="8dp"/>
                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbMale"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Masculino"
                        android:layout_marginBottom="8dp"/>
                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbNonBinary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No binario"/>
                </RadioGroup>
            </LinearLayout>

            <!-- PASO 1: Personalidad -->
            <LinearLayout android:id="@+id/step1Layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Como es su personalidad?"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginBottom="6dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Elige como quieres que se comporte contigo."
                    android:textSize="13sp"
                    android:textColor="#9E9E9E"
                    android:layout_marginBottom="20dp"/>

                <RadioGroup android:id="@+id/rgPersonality"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="24dp">
                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbSweet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Carinosa - Afectuosa y empatica"
                        android:checked="true"
                        android:layout_marginBottom="8dp"/>
                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbFunny"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Divertida - Humor y alegria"
                        android:layout_marginBottom="8dp"/>
                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbSerious"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Seria - Reflexiva e intelectual"
                        android:layout_marginBottom="8dp"/>
                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbFlirty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Coqueta - Picara y encantadora"
                        android:layout_marginBottom="8dp"/>
                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbAdventurous"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Aventurera - Curiosa y apasionada"/>
                </RadioGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Forma de hablar"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginBottom="12dp"/>

                <RadioGroup android:id="@+id/rgSpeech"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbCasual"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Casual - Natural y relajada"
                        android:checked="true"
                        android:layout_marginBottom="8dp"/>
                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbFormal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Formal - Educada y elegante"
                        android:layout_marginBottom="8dp"/>
                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbYouth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Juvenil - Slang moderno"/>
                </RadioGroup>
            </LinearLayout>

            <!-- PASO 2: Nivel emocional -->
            <LinearLayout android:id="@+id/step2Layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nivel de cercania emocional"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginBottom="6dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Que tan expresivo/a quieres que sea contigo?"
                    android:textSize="13sp"
                    android:textColor="#9E9E9E"
                    android:layout_marginBottom="20dp"/>

                <RadioGroup android:id="@+id/rgEmotional"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbLow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reservado - Calido pero moderado"
                        android:layout_marginBottom="8dp"/>
                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbMedium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cercano - Carino equilibrado"
                        android:checked="true"
                        android:layout_marginBottom="8dp"/>
                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/rbHigh"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Muy cercano - Muy expresivo/a"/>
                </RadioGroup>
            </LinearLayout>

            <!-- PASO 3: Intereses -->
            <LinearLayout android:id="@+id/step3Layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cuales son sus intereses?"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginBottom="6dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selecciona los temas que le apasionan."
                    android:textSize="13sp"
                    android:textColor="#9E9E9E"
                    android:layout_marginBottom="20dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupInterests"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="false">
                    <com.google.android.material.chip.Chip style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Musica"/>
                    <com.google.android.material.chip.Chip style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cine"/>
                    <com.google.android.material.chip.Chip style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Libros"/>
                    <com.google.android.material.chip.Chip style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Videojuegos"/>
                    <com.google.android.material.chip.Chip style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Comida"/>
                    <com.google.android.material.chip.Chip style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Deporte"/>
                    <com.google.android.material.chip.Chip style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Viajes"/>
                    <com.google.android.material.chip.Chip style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Arte"/>
                    <com.google.android.material.chip.Chip style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tecnologia"/>
                    <com.google.android.material.chip.Chip style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Naturaleza"/>
                    <com.google.android.material.chip.Chip style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ciencia"/>
                    <com.google.android.material.chip.Chip style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Animales"/>
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>

            <!-- PASO 4: Foto -->
            <LinearLayout android:id="@+id/step4Layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Foto de perfil"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginBottom="6dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Elige una foto para tu companero/a (opcional)."
                    android:textSize="13sp"
                    android:textColor="#9E9E9E"
                    android:gravity="center"
                    android:layout_marginBottom="32dp"/>

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/ivAvatarPreview"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/ic_avatar_default"
                    app:civ_border_width="2dp"
                    app:civ_border_color="#000000"
                    android:layout_marginBottom="20dp"/>

                <LinearLayout
                    android:id="@+id/btnPickAvatar"
                    android:layout_width="160dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_button_outline"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Elegir foto"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Botones de navegacion -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="4dp">

        <LinearLayout
            android:id="@+id/btnBack"
            android:layout_width="100dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_button_outline"
            android:gravity="center"
            android:layout_marginEnd="10dp"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Atras"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnNext"
            android:layout_width="120dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_button_black"
            android:gravity="center">
            <TextView
                android:id="@+id/tvNextLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Siguiente"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
