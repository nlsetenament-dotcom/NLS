<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#F5F5F5">

    <!-- Toolbar negro -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#000000"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="8dp">

        <ImageButton
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="#FFFFFF"
            android:contentDescription="Volver"
            android:onClick="finish"/>

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/ivToolbarAvatar"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_avatar_default"
            app:civ_border_width="1.5dp"
            app:civ_border_color="#333333"
            android:layout_marginStart="4dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tvToolbarName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Luna"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <View
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:background="@drawable/circle_online"
                    android:layout_marginEnd="4dp"/>
                <TextView
                    android:id="@+id/tvToolbarStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="En linea"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <ImageButton
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_more_vert"
            android:tint="#FFFFFF"
            android:contentDescription="Mas opciones"
            android:onClick="openOptionsMenu"/>
    </LinearLayout>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"
        android:scrollbars="none"/>

    <!-- Typing indicator -->
    <LinearLayout
        android:id="@+id/layoutTyping"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone">

        <de.hdodenhof.circleimageview.CircleImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_avatar_default"
            android:layout_marginEnd="6dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bubble_received"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/tvTypingDot1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="#000000"
                android:textSize="10sp"
                android:layout_marginEnd="3dp"/>
            <TextView
                android:id="@+id/tvTypingDot2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="#000000"
                android:textSize="10sp"
                android:layout_marginEnd="3dp"/>
            <TextView
                android:id="@+id/tvTypingDot3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="#000000"
                android:textSize="10sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Input area blanca -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:padding="10dp"
        android:elevation="4dp">

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_input_field"
            android:hint="Escribe un mensaje..."
            android:textColorHint="#9E9E9E"
            android:textColor="#000000"
            android:textSize="15sp"
            android:maxLines="4"
            android:inputType="textMultiLine|textCapSentences"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnSend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_send"
            app:backgroundTint="#000000"
            app:fabSize="mini"
            android:contentDescription="Enviar"/>
    </LinearLayout>
</LinearLayout>
